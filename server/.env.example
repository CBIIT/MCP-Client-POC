# This is an example .env file for the server. Copy this file to .env and fill in the values.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=

AWS_DEFAULT_REGION=us-east-1
AWS_REGION=us-east-1

# Enables https (will generate a self-signed certificate)
PORT=443

# Sets the version of the application (available under /api/status)
VERSION=1.0.0

# Skip SSL verification for local development (eg: using self-signed certificates)
NODE_TLS_REJECT_UNAUTHORIZED=0

# Serve static assets from the client folder
CLIENT_FOLDER=../client

# Set session secret for signing cookies (replace with a strong secret)
SESSION_SECRET=session-secret

# Database settings - SWITCHED TO SQLITE FOR POC ISOLATION
DB_DIALECT=sqlite
DB_STORAGE=./database.sqlite



# MCP Server Tokens
# Add your GitHub personal access token here
# Create one at: https://github.com/settings/tokens
GITHUB_TOKEN=""
